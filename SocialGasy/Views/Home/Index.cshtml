@{
    ViewData["Title"] = "Tableau de Bord - SocialGasy";
}

<div class="hero-section text-white d-flex align-items-center justify-content-center text-center mb-5" 
     style="background: linear-gradient(rgba(78, 115, 223, 0.9), rgba(26, 28, 35, 0.9)), url('https://images.unsplash.com/photo-1577412647305-991150c7d163?q=80&w=2000'); background-size: cover; height: 350px; border-radius: 0 0 50px 50px;">
    <div class="container">
        <h1 class="display-3 fw-bold">Bienvenue sur SocialGasy</h1>
        <p class="lead">Plateforme de gestion et de pilotage du recensement national.</p>
    </div>
</div>

<div class="container">
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-person-plus-fill display-4 mb-3" style="color: var(--primary);"></i>
                <h5 class="fw-bold">Ajouter un Chef</h5>
                <a asp-controller="Admin" asp-action="CreateChef" class="btn btn-primary rounded-pill mt-3 px-4">Créer</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-envelope-paper text-success display-4 mb-3"></i>
                <h5 class="fw-bold">Rapports</h5>
                <a asp-controller="Admin" asp-action="Notifications" class="btn btn-success text-white rounded-pill mt-3 px-4">Consulter</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-gear-fill text-warning display-4 mb-3"></i>
                <h5 class="fw-bold">Configuration</h5>
                <a asp-controller="Admin" asp-action="ListChefs" class="btn btn-warning text-white rounded-pill mt-3 px-4">Gérer</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden p-4" style="background-color: var(--sidebar-bg); color: #fff;">
                <div class="d-flex align-items-center">
                    <div class="me-4"><i class="bi bi-info-circle-fill text-primary display-4"></i></div>
                    <div>
                        <h5 class="fw-bold text-primary">Le saviez-vous ?</h5>
                        <p class="mb-0 fs-5">@ViewBag.FactOfTheDay</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important;
    }
    .hero-section {
        animation: fadeIn 1.2s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>