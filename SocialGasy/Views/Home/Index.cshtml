@{
    ViewData["Title"] = "Tableau de Bord - SocialGasy";
}

<!-- Hero Section -->
<div class="hero-section text-white d-flex align-items-center justify-content-center text-center mb-5" 
     style="background: linear-gradient(rgba(13, 110, 253, 0.85), rgba(13, 110, 253, 0.85)), url('https://images.unsplash.com/photo-1577412647305-991150c7d163?q=80&w=2000'); background-size: cover; height: 350px; border-radius: 0 0 50px 50px;">
    <div class="animate__animated animate__fadeInDown">
        <h1 class="display-3 fw-bold">Bienvenue sur SocialGasy</h1>
        <p class="lead">Plateforme de gestion et de pilotage du recensement national.</p>
    </div>
</div>

<div class="container">
    <!-- Actions Rapides -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-person-plus-fill text-primary display-4 mb-3"></i>
                <h5 class="fw-bold">Ajouter un Chef</h5>
                <a asp-controller="Admin" asp-action="CreateChef" class="btn btn-primary rounded-pill mt-3 px-4">Créer</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-envelope-paper text-success display-4 mb-3"></i>
                <h5 class="fw-bold">Rapports</h5>
                <a asp-controller="Admin" asp-action="Notifications" class="btn btn-success text-white rounded-pill mt-3 px-4">Consulter</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 text-center card-hover">
                <i class="bi bi-gear-fill text-warning display-4 mb-3"></i>
                <h5 class="fw-bold">Configuration</h5>
                <a asp-controller="Admin" asp-action="ListChefs" class="btn btn-warning text-white rounded-pill mt-3 px-4">Gérer</a>
            </div>
        </div>
    </div>

    <!-- Le Saviez-vous (Le message mahaliana) -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-dark text-white p-4">
                <div class="d-flex align-items-center">
                    <div class="me-4"><i class="bi bi-info-circle-fill text-info display-4"></i></div>
                    <div>
                        <h5 class="fw-bold text-info">Le saviez-vous ?</h5>
                        <p class="mb-0 fs-5">@ViewBag.FactOfTheDay</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Animation sy Style */
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .hero-section {
        animation: fadeIn 1.5s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>