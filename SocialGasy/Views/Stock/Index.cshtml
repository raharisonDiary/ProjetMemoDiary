@using Microsoft.Extensions.Localization
@using SocialGasy
@inject IStringLocalizer<SharedResource> Localizer
@model IEnumerable<SocialGasy.Models.Stock>

@{
    ViewData["Title"] = Localizer["StockManagementTitle"];
    double lowStockThreshold = 50; 
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 animate__animated animate__fadeIn">
        <div>
            <h2 class="fw-bold text-dark text-uppercase mb-1">
                <i class="bi bi-box-seam text-primary me-2"></i>@Localizer["NeighborhoodStock"]
            </h2>
            <p class="text-muted small mb-0">Fanaraha-maso ny entana sy ny vatsy isaky ny Fokontany.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="mt-3 mt-md-0">
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>@Localizer["AddNewItem"]
                </a>
            </div>
        }
    </div>

    <div class="row g-4 animate__animated animate__fadeInUp">
        @foreach (var item in Model)
        {
            bool isLowStock = item.Quantity <= lowStockThreshold;
            bool isExpired = item.ExpiryDate < DateTime.UtcNow;

            <div class="col-xl-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-card">
                    
                    @if (isExpired) {
                        <div class="position-absolute top-0 start-0 w-100 h-100 bg-danger bg-opacity-10 pointer-events-none" style="z-index: 0;"></div>
                    }

                    <div class="card-body p-4 position-relative" style="z-index: 1;">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold text-dark mb-1">@item.ItemName</h5>
                                <span class="badge bg-light text-muted border px-2 py-1 x-small fw-normal">
                                    LOT: <span class="fw-bold">@item.BatchNumber</span>
                                </span>
                            </div>
                            <div class="d-flex flex-column gap-1">
                                @if (isExpired) {
                                    <span class="badge bg-danger rounded-pill shadow-sm animate__animated animate__pulse animate__infinite">
                                        <i class="bi bi-exclamation-octagon me-1"></i> @Localizer["ExpiredAlert"]
                                    </span>
                                }
                                else if (isLowStock) {
                                    <span class="badge bg-warning text-dark rounded-pill shadow-sm">
                                        <i class="bi bi-graph-down-arrow me-1"></i> @Localizer["LowStockAlert"]
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="rounded-4 p-3 mb-4 bg-light bg-opacity-75 border border-white">
                            <div class="row align-items-center">
                                <div class="col-7">
                                    <small class="text-muted text-uppercase fw-bold x-small d-block mb-1">@Localizer["CurrentQuantity"]</small>
                                    <h3 class="fw-extrabold mb-0 @(isLowStock ? "text-danger" : "text-primary")">
                                        @item.Quantity <small class="fs-6 fw-normal text-muted">@item.Unit</small>
                                    </h3>
                                </div>
                                <div class="col-5 text-end border-start">
                                    <small class="text-muted text-uppercase fw-bold x-small d-block mb-1">@Localizer["Fokontany"]</small>
                                    <span class="text-dark fw-bold">@item.Fokontany</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between p-2 rounded-pill @(isExpired ? "bg-danger bg-opacity-10 text-danger" : "bg-light text-muted")">
                            <div class="small ms-2">
                                <i class="bi bi-calendar-event me-2"></i>
                                @Localizer["ExpiryDateLabel"]: <span class="fw-bold">@item.ExpiryDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            @if (!isExpired) {
                                <i class="bi bi-check2-circle text-success me-2"></i>
                            }
                        </div>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="card-footer bg-white border-0 py-3 px-4 d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm flex-grow-1 rounded-pill">
                                <i class="bi bi-pencil me-1"></i> Hanova
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm flex-grow-1 rounded-pill">
                                <i class="bi bi-eye me-1"></i> Tsipiriany
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 animate__animated animate__fadeIn">
            <div class="bg-light d-inline-flex p-5 rounded-circle mb-4">
                <i class="bi bi-box display-1 text-muted opacity-25"></i>
            </div>
            <h4 class="text-dark fw-bold">@Localizer["NoStockItemsFound"]</h4>
            <p class="text-muted">Tsy mbola misy entana voasoratra ato amin'ny tahiry.</p>
            @if (User.IsInRole("Admin")) {
                <a asp-action="Create" class="btn btn-primary mt-3">Hampiditra voalohany</a>
            }
        </div>
    }
</div>

<style>
    .fw-extrabold { font-weight: 800; }
    .x-small { font-size: 0.7rem; }
    .hover-card { transition: all 0.3s ease; border: 1px solid transparent !important; }
    .hover-card:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important; border-color: rgba(13, 110, 253, 0.1) !important; }
    .bg-gradient-warning { background: linear-gradient(45deg, #ffc107, #ff9800); }
    .pointer-events-none { pointer-events: none; }
</style>