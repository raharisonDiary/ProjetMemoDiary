@{
    ViewData["Title"] = "Statistiques Globales";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h3 class="fw-bold text-dark m-0">Tableau de Bord</h3>
            <p class="text-muted small">Analyse des données démographiques</p>
        </div>
        <form method="get" class="col-12 col-md-auto">
            <select name="district" onchange="this.form.submit()" class="form-select border-0 shadow-sm rounded-pill px-4 bg-white">
                <option value="">Tous les districts</option>
                @foreach (var d in ViewBag.Districts)
                {
                    <option value="@d" selected="@(ViewBag.SelectedDistrict == d)">@d</option>
                }
            </select>
        </form>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card p-4 border-0 rounded-4 shadow-sm text-center h-100 bg-primary text-white">
                <h6 class="text-uppercase opacity-75">Population Totale</h6>
                <h2 class="fw-bold display-6">@ViewBag.TotalCitizens</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 border-0 rounded-4 shadow-sm text-center h-100 bg-success text-white">
                <h6 class="text-uppercase opacity-75">Ménages</h6>
                <h2 class="fw-bold display-6">@ViewBag.TotalHouseholds</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4 border-0 rounded-4 shadow-sm h-100">
                <h6 class="fw-bold mb-3 text-secondary">Top 5 Districts (Population)</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var top in ViewBag.TopDistricts)
                    {
                        <div class="badge bg-light text-dark p-2 px-3 rounded-pill border shadow-sm">
                            <span class="fw-bold">@top["_id"]</span>: @top["Count"] hab
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 border-0 rounded-4 shadow-sm h-100">
                <h6 class="fw-bold mb-4">Répartition par Âge et Sexe</h6>
                <canvas id="ageChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card p-4 border-0 rounded-4 shadow-sm h-100">
                <h6 class="fw-bold mb-4">Répartition par Genre</h6>
                <canvas id="genderChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const rawStats = @Json.Serialize(ViewBag.Stats);
        const ageGroups = ["Mineur (<18)", "Jeune (18-35)", "Adulte (36-60)", "Senior (>60)"];

        // Bar Chart (Age & Gender)
        new Chart(document.getElementById('ageChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: ageGroups,
                datasets: [
                    { label: 'Hommes', data: ageGroups.map(g => rawStats.filter(s => s.ageGroup === g && s.gender === 'M').reduce((a, b) => a + b.count, 0)), backgroundColor: '#0d6efd', borderRadius: 8 },
                    { label: 'Femmes', data: ageGroups.map(g => rawStats.filter(s => s.ageGroup === g && s.gender === 'F').reduce((a, b) => a + b.count, 0)), backgroundColor: '#d63384', borderRadius: 8 }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } } }
        });

        // Doughnut Chart (Gender)
        new Chart(document.getElementById('genderChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Hommes', 'Femmes'],
                datasets: [{
                    data: [
                        rawStats.filter(s => s.gender === 'M').reduce((a, b) => a + b.count, 0),
                        rawStats.filter(s => s.gender === 'F').reduce((a, b) => a + b.count, 0)
                    ],
                    backgroundColor: ['#0d6efd', '#d63384'],
                    borderWidth: 0
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
    </script>
}