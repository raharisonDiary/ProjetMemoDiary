@{
    ViewData["Title"] = "Connexion - SocialGasy";
    Layout = "_Layout";
}

<style>
    :root {
        --primary-color: #4f46e5;
        --secondary-color: #0d1128;
        --transition-speed: 0.6s;
    }

    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f0f2f5;
    }

    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        width: 100%;
        padding: 20px;
    }

    .login-card {
        display: flex;
        width: 100%;
        max-width: 900px;
        background: #fff;
        border-radius: 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        min-height: 500px;
        position: relative;
    }

    .form-side, .info-side {
        width: 50%;
        transition: transform var(--transition-speed) cubic-bezier(0.68, -0.55, 0.265, 1.55);
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .form-side {
        padding: 40px;
    }

    .info-side {
        background: linear-gradient(165deg, var(--secondary-color) 0%, #1e293b 100%);
        color: #fff;
        align-items: center;
        text-align: center;
        padding: 40px;
    }

    .form-control {
        border-radius: 15px;
        padding: 12px;
        border: 1px solid #ddd;
    }

    .btn-primary {
        background: var(--primary-color);
        border: none;
        padding: 12px;
        border-radius: 15px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .login-card {
            flex-direction: column;
            min-height: auto;
            border-radius: 20px;
        }
        .form-side, .info-side {
            width: 100%;
            padding: 25px;
        }
        .info-side {
            order: -1;
        }
        .switched .form-side, .switched .info-side {
            transform: none !important;
            animation: fadeIn 0.5s ease-in-out;
        }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .switched .form-side { transform: translateX(100%); }
    .switched .info-side { transform: translateX(-100%); }

    #reader {
        border-radius: 20px;
        overflow: hidden;
        border: 2px dashed var(--primary-color);
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
    }
</style>

<div class="login-container">
    <div class="login-card" id="mainCard">
        <div class="form-side" id="formSide">
            <h2 id="titleAction" class="fw-bold mb-4 text-primary">Connexion Admin</h2>
            <div id="adminForm">
                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <input type="text" name="username" class="form-control" placeholder="Nom d'utilisateur" required />
                    </div>
                    <div class="mb-3">
                        <input type="password" name="password" class="form-control" placeholder="Mot de passe" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">SE CONNECTER</button>
                </form>
            </div>
            
            <div id="agentForm" class="d-none">
                <div id="reader" class="mb-3"></div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Sélectionnez une image QR :</label>
                    <input type="file" id="qr-input-file" accept="image/*" class="form-control">
                </div>
                <div id="statusMessage" class="alert alert-info mt-2 d-none">Vérification en cours...</div>
            </div>

            <button class="btn btn-link w-100 mt-3 text-decoration-none" id="toggleBtn">Passer en mode Agent</button>
        </div>

        <div class="info-side" id="infoSide">
            <h1 class="display-5 fw-bold mb-3">SOCIALGASY</h1>
            <p id="infoDesc" class="lead text-white-50">Plateforme de gestion administrative sécurisée.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const html5QrCode = new Html5Qrcode("reader");
            let isAgentMode = false;
            const toggleBtn = document.getElementById('toggleBtn');

            toggleBtn.addEventListener('click', function() {
                isAgentMode = !isAgentMode;
                const card = document.getElementById('mainCard');
                const title = document.getElementById('titleAction');
                const adminForm = document.getElementById('adminForm');
                const agentForm = document.getElementById('agentForm');
                const infoDesc = document.getElementById('infoDesc');

                if (isAgentMode) {
                    card.classList.add('switched');
                    title.innerText = "Connexion Agent";
                    adminForm.classList.add('d-none');
                    agentForm.classList.remove('d-none');
                    toggleBtn.innerText = "Passer en mode Admin";
                    infoDesc.innerText = "Scannez votre code QR pour accéder à votre tableau de bord.";
                    setTimeout(startCamera, 600);
                } else {
                    card.classList.remove('switched');
                    title.innerText = "Connexion Admin";
                    adminForm.classList.remove('d-none');
                    agentForm.classList.add('d-none');
                    toggleBtn.innerText = "Passer en mode Agent";
                    infoDesc.innerText = "Plateforme de gestion administrative sécurisée.";
                    if(html5QrCode.isScanning) html5QrCode.stop();
                }
            });

            function startCamera() {
                html5QrCode.start(
                    { facingMode: "environment" }, 
                    { fps: 10, qrbox: { width: 250, height: 250 } },
                    (decodedText) => processScan(decodedText)
                ).catch(err => console.log(err));
            }

            function processScan(token) {
                if (html5QrCode.isScanning) {
                    html5QrCode.stop().then(() => sendScanData(token));
                } else {
                    sendScanData(token);
                }
            }

            function sendScanData(token) {
                $('#statusMessage').removeClass('d-none').text('Vérification...');
                $.ajax({
                    url: '@Url.Action("LoginByScan", "Account")',
                    type: 'POST',
                    data: { token: token.trim() },
                    headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                    success: function(res) {
                        if (res.success) {
                            window.location.href = res.redirectUrl;
                        } else {
                            $('#statusMessage').addClass('d-none');
                            Swal.fire('Erreur', res.message, 'error').then(startCamera);
                        }
                    },
                    error: function() {
                        $('#statusMessage').addClass('d-none');
                        Swal.fire('Erreur', 'Échec de la connexion !', 'error').then(startCamera);
                    }
                });
            }

            $('#qr-input-file').on('change', e => {
                if (e.target.files.length == 0) return;
                const file = e.target.files[0];
                if (html5QrCode.isScanning) {
                    html5QrCode.stop().then(() => {
                        html5QrCode.scanFile(file, true)
                            .then(decodedText => processScan(decodedText))
                            .catch(() => Swal.fire('Erreur', 'Code QR non trouvé.', 'error'));
                    });
                } else {
                    html5QrCode.scanFile(file, true)
                        .then(decodedText => processScan(decodedText))
                        .catch(() => Swal.fire('Erreur', 'Code QR non trouvé.', 'error'));
                }
            });
        });
    </script>
}