@model SocialGasy.Models.Citizen
@{ 
    ViewData["Title"] = "Détails du Citoyen"; 
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Liste des habitants</a></li>
            <li class="breadcrumb-item active" aria-current="page">Détails</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white border-bottom p-4">
            <div class="d-flex align-items-center">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                    <i class="bi bi-person-fill fs-4"></i>
                </div>
                <div>
                    <h4 class="mb-0 fw-bold">@Model.LastName @Model.FirstName</h4>
                    <span class="text-muted small">Informations personnelles et foyer</span>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="ratio ratio-1x1 border rounded-3 bg-light overflow-hidden shadow-sm">
                        @if (!string.IsNullOrEmpty(Model.PhotoBase64)) {
                            <img src="@Model.PhotoBase64" class="object-fit-cover" alt="Photo" />
                        } else {
                            <div class="d-flex flex-column align-items-center justify-content-center text-muted">
                                <i class="bi bi-person-bounding-box fs-1"></i>
                                <span class="small mt-2">Aucune photo</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="row mb-4">
                        <div class="col-12"><h5 class="text-primary fw-bold mb-3"><i class="bi bi-person-badge me-2"></i>État Civil</h5></div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Numéro CIN</label>
                            <span class="fw-semibold">@Model.CIN</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Sexe</label>
                            <span class="badge bg-light text-dark border">@Model.Gender</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Statut Matrimonial</label>
                            <span class="fw-semibold">@Model.MaritalStatus</span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="text-muted small d-block">Téléphone</label>
                            <span class="fw-semibold">@Model.PhoneNumber</span>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row">
                        <div class="col-12"><h5 class="text-primary fw-bold mb-3"><i class="bi bi-house-door me-2"></i>Informations du Ménage</h5></div>
                        @if (ViewBag.Household != null)
                        {
                            <div class="col-sm-4 mb-3">
                                <label class="text-muted small d-block">Fokontany</label>
                                <span class="fw-semibold text-dark">@ViewBag.Household.Fokontany</span>
                            </div>
                            <div class="col-sm-4 mb-3">
                                <label class="text-muted small d-block">District</label>
                                <span class="fw-semibold text-dark">@ViewBag.Household.District</span>
                            </div>
                            <div class="col-sm-12">
                                <label class="text-muted small d-block">Adresse complète</label>
                                <span class="fw-semibold text-dark">@ViewBag.Household.Address</span>
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="alert alert-warning border-0 bg-light-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i> Aucune information de ménage associée.
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light p-3 text-end">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-1"></i> Retour
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .object-fit-cover { width: 100%; height: 100%; object-fit: cover; }
        .bg-light-warning { color: #856404; }
    </style>
}