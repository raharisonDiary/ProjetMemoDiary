@model SocialGasy.Models.Citizen

@{
    ViewData["Title"] = "Détails du Citoyen";
}

<div class="page-background py-5">
    <div class="container animate__animated animate__fadeIn">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-white-50">Liste des habitants</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">Détails</li>
            </ol>
        </nav>

        <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
            <div class="card-header bg-primary text-white p-4 border-0 text-center">
                <h3 class="fw-bold mb-1"><i class="bi bi-person-badge-fill me-2"></i> Détails du Citoyen</h3>
                <p class="mb-0 text-white-75 small text-uppercase tracking-wide">Fiche d'identité et état civil</p>
            </div>

            <div class="card-body p-4 p-lg-5 bg-white">
                <div class="row g-5">
                    <div class="col-lg-3 text-center">
                        <div class="ratio ratio-1x1 border border-4 border-light rounded-5 bg-dark overflow-hidden shadow-sm mx-auto">
                            @if (!string.IsNullOrEmpty(Model.PhotoBase64))
                            {
                                <img src="@Model.PhotoBase64" class="object-fit-cover" alt="Photo du citoyen" />
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center text-white-50">
                                    <i class="bi bi-person-bounding-box fs-1"></i>
                                    <span class="small mt-2">Aucune photo</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-lg-9">
                        <div class="row mb-5">
                            <div class="col-12"><h5 class="text-primary fw-bold mb-4 border-bottom pb-2"><i class="bi bi-person-fill me-2"></i> État Civil</h5></div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Numéro CIN</label>
                                <span class="fw-semibold fs-5 text-dark">@Model.CIN</span>
                            </div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Sexe</label>
                                <span class="badge bg-light text-dark border px-3 py-2 fs-6">@Model.Gender</span>
                            </div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Statut Matrimonial</label>
                                <span class="fw-semibold fs-5 text-dark">@Model.MaritalStatus</span>
                            </div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Conjoint(e)</label>
                                <span class="fw-semibold fs-5 text-dark">@(string.IsNullOrEmpty(Model.SpouseName) ? "Non renseigné" : Model.SpouseName)</span>
                            </div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Nombre d'enfants</label>
                                <span class="fw-semibold fs-5 text-dark">@Model.NumberOfChildren</span>
                            </div>
                            <div class="col-sm-6 mb-4">
                                <label class="text-muted small d-block text-uppercase fw-bold">Profession</label>
                                <span class="fw-semibold fs-5 text-dark">@(string.IsNullOrEmpty(Model.Profession) ? "Non renseigné" : Model.Profession)</span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12"><h5 class="text-primary fw-bold mb-4 border-bottom pb-2"><i class="bi bi-house-door-fill me-2"></i> Informations du Ménage</h5></div>
                            @if (ViewBag.Household != null)
                            {
                                <div class="col-sm-4 mb-3">
                                    <label class="text-muted small d-block text-uppercase fw-bold">Fokontany</label>
                                    <span class="fw-bold text-dark fs-5">@ViewBag.Household.Fokontany</span>
                                </div>
                                <div class="col-sm-4 mb-3">
                                    <label class="text-muted small d-block text-uppercase fw-bold">District</label>
                                    <span class="fw-bold text-dark fs-5">@ViewBag.Household.District</span>
                                </div>
                                <div class="col-sm-4 mb-3">
                                    <label class="text-muted small d-block text-uppercase fw-bold">Région</label>
                                    <span class="fw-bold text-dark fs-5">@ViewBag.Household.Region</span>
                                </div>
                                <div class="col-12 mt-3">
                                    <label class="text-muted small d-block text-uppercase fw-bold">Adresse complète</label>
                                    <span class="fw-bold text-dark fs-5">@ViewBag.Household.Address</span>
                                </div>
                            }
                            else
                            {
                                <div class="col-12">
                                    <div class="alert alert-warning border-0 rounded-4 shadow-sm p-3">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Aucune information de ménage associée.
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-light p-4 text-end border-0">
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 rounded-4 hover-lift">
                    <i class="bi bi-arrow-left me-2"></i> Retour
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .page-background { min-height: 100vh; background: linear-gradient(135deg, #0f172a 0%, #334155 100%); padding-bottom: 2rem; }
        .object-fit-cover { width: 100%; height: 100%; object-fit: cover; }
        .hover-lift { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important; }
        .rounded-5 { border-radius: 2rem !important; }
        .rounded-4 { border-radius: 1.25rem !important; }
        
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }

        @@media (max-width: 768px) {
            .card-body { padding: 1.5rem !important; }
        }
    </style>
}