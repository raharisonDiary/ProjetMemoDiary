@model IEnumerable<SocialGasy.Models.Citizen>
@{
    ViewData["Title"] = "Liste des Habitants";
}

<div class="page-background py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div>
                <h2 class="fw-bold text-white mb-1">Liste des Habitants</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none opacity-75">Accueil</a></li>
                        <li class="breadcrumb-item active text-white fw-bold">Citoyens</li>
                    </ol>
                </nav>
            </div>
            <a asp-action="Create" class="btn btn-light btn-lg rounded-4 shadow-sm text-primary fw-bold hover-lift">
                <i class="bi bi-person-plus-fill me-2"></i> Nouveau Citoyen
            </a>
        </div>

        <div class="card border-0 shadow-lg rounded-5 mb-4 p-2">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-4"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" id="searchInput" class="form-control border-start-0 border-end-0" placeholder="Rechercher par nom, CIN ou profession...">
                            <span class="input-group-text bg-white border-start-0 rounded-end-4"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select id="filterGender" class="form-select form-select-lg rounded-4 border-light shadow-sm">
                            <option value="">Tous les genres</option>
                            <option value="Masculin">Masculin</option>
                            <option value="Féminin">Féminin</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="citizenTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">CIN</th>
                            <th class="py-3">Nom</th>
                            <th class="py-3">Prénom</th>
                            <th class="py-3">Sexe</th>
                            <th class="py-3">Statut</th>
                            <th class="py-3 text-center">Enfants</th>
                            <th class="py-3 text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="citizen-row" data-gender="@item.Gender">
                                <td class="ps-4 fw-bold text-primary">@item.CIN</td>
                                <td class="fw-semibold">@item.LastName</td>
                                <td>@item.FirstName</td>
                                <td>
                                    <span class="badge rounded-pill @(item.Gender == "Masculin" ? "bg-primary" : "bg-danger") px-3">
                                        @item.Gender
                                    </span>
                                </td>
                                <td>@item.MaritalStatus</td>
                                <td class="text-center font-monospace fw-bold">@item.NumberOfChildren</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-start-pill px-3"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-3"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-end-pill px-3"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e293b 0%, #4e73df 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 15px rgba(0,0,0,0.2) !important; }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            function filterTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let genderFilter = $('#filterGender').val();

                $('.citizen-row').each(function() {
                    let text = $(this).text().toLowerCase();
                    let gender = $(this).data('gender');
                    
                    let matchesSearch = text.includes(searchTerm);
                    let matchesGender = (genderFilter === "" || gender === genderFilter);

                    $(this).toggle(matchesSearch && matchesGender);
                });
            }

            $('#searchInput').on('keyup', filterTable);
            $('#filterGender').on('change', filterTable);
        });
    </script>
}