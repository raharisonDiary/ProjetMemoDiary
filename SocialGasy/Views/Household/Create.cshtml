@model SocialGasy.Models.Household
@{
    ViewData["Title"] = "Ajouter un Ménage";
}

<div class="page-background py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <h3 class="fw-bold mb-1"><i class="bi bi-house-add-fill me-2"></i> Nouveau Ménage</h3>
                        <p class="mb-0 text-white-75 small text-uppercase tracking-wide">Enregistrement des données</p>
                    </div>

                    <div class="card-body p-4 p-lg-5 bg-white">
                        <form asp-action="Create" method="post" autocomplete="off" id="householdForm">
                            @Html.AntiForgeryToken()

                            <div class="mb-4 text-center">
                                <div id="gps-status" class="bg-light p-3 mb-2 rounded-4 border border-secondary border-opacity-25">
                                    <div class="spinner-grow spinner-grow-sm text-primary me-2"></div>
                                    <span class="text-muted small fw-bold">Recherche GPS en cours...</span>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="getLocation()">
                                    <i class="bi bi-arrow-clockwise me-1"></i> Actualiser GPS
                                </button>
                                <input type="hidden" asp-for="Latitude" id="Latitude" />
                                <input type="hidden" asp-for="Longitude" id="Longitude" />
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Region" class="form-label text-dark fw-bold small">Région</label>
                                    <input asp-for="Region" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Entrez la région" required />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="District" class="form-label text-dark fw-bold small">District</label>
                                    <input asp-for="District" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Entrez le district" required />
                                </div>
                            </div>

                            <div class="mt-3">
                                <label asp-for="Commune" class="form-label text-dark fw-bold small">Commune</label>
                                <input asp-for="Commune" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Entrez la commune" required />
                            </div>

                            <div class="mt-3">
                                <label asp-for="Fokontany" class="form-label text-dark fw-bold small">Fokontany</label>
                                <input asp-for="Fokontany" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Entrez le fokontany" required />
                            </div>

                            <div class="mt-3 mb-4">
                                <label asp-for="Address" class="form-label text-dark fw-bold small">Adresse précise</label>
                                <input asp-for="Address" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Rue, quartier, référence..." required />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" id="btn-submit" class="btn btn-primary btn-lg rounded-4 shadow-sm py-3 hover-lift fw-bold">
                                    <i class="bi bi-check2-circle me-2"></i> Enregistrer le ménage
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-4 py-3 fw-bold border-0 hover-lift">
                                    <i class="bi bi-arrow-left me-2"></i> Annuler et retourner
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background { min-height: 100vh; background: linear-gradient(135deg, #0f172a 0%, #334155 100%); }
    .form-control-lg { padding: 0.8rem 1.25rem; font-size: 1rem; transition: all 0.3s ease; }
    .form-control-lg:focus { border-color: #4e73df !important; box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.25) !important; }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 15px rgba(0,0,0,0.2) !important; }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>

@section Scripts {
    <script>
        const form = document.getElementById('householdForm');

        function getLocation() {
            const gpsStatus = document.getElementById("gps-status");
            const latInput = document.getElementById("Latitude");
            const lngInput = document.getElementById("Longitude");

            gpsStatus.innerHTML = '<div class="spinner-grow spinner-grow-sm text-primary me-2"></div> Localisation...';

            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        const lat = pos.coords.latitude.toFixed(6);
                        const lng = pos.coords.longitude.toFixed(6);
                        latInput.value = lat;
                        lngInput.value = lng;
                        gpsStatus.innerHTML = `<div class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Localisé: ${lat}, ${lng}</div>`;
                    },
                    (err) => { 
                        gpsStatus.innerHTML = `<div class="text-danger fw-bold small"><i class="bi bi-x-circle-fill"></i> Erreur: ${err.message}</div>`;
                    },
                    { enableHighAccuracy: true, timeout: 15000 }
                );
            } else {
                gpsStatus.innerHTML = '<div class="text-warning small">Géolocalisation non supportée.</div>';
            }
        }
        document.addEventListener("DOMContentLoaded", getLocation);

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(form);
            const data = {};
            formData.forEach((value, key) => {
                data[key] = value;
            });

            if (!navigator.onLine) {
                storeOffline('household', data);
                alert("Ménage enregistré hors ligne.");
                window.location.href = '@Url.Action("Index")';
            } else {
                fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value 
                    }
                })
                .then(response => {
                    if (response.ok) {
                        window.location.href = '@Url.Action("Index")';
                    } else {
                        throw new Error('Server error');
                    }
                })
                .catch(() => {
                    storeOffline('household', data);
                    alert("Erreur réseau, enregistré hors ligne.");
                    window.location.href = '@Url.Action("Index")';
                });
            }
        });
    </script>
}