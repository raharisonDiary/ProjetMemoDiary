@model IEnumerable<SocialGasy.Models.Household>
@{
    ViewData["Title"] = "Registre des Ménages";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-0">Registre des Ménages</h2>
            <p class="text-muted small">Suivi national des habitations et géolocalisation</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Nouveau Ménage
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Région / District</th>
                        <th>Fokontany / Adresse</th>
                        <th>Coordonnées GPS</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-house-door display-4 d-block mb-2 opacity-50"></i>
                                Aucun ménage enregistré pour le moment.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            // Utilisation du point comme séparateur décimal
                            var lat = item.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                            var lon = item.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Region</div>
                                    <small class="text-muted">@item.District</small>
                                </td>
                                <td>
                                    <div class="text-primary fw-semibold">@item.Fokontany</div>
                                    <small class="text-muted">@item.Address</small>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill font-monospace px-3">
                                        @lat, @lon
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="https://www.openstreetmap.org/?mlat=@lat&mlon=@lon#map=18/@lat/@lon" 
                                       target="_blank" 
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-map me-1"></i> Carte
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table > :not(caption) > * > * { padding: 1rem; }
    .badge { font-size: 0.85em; }
    .btn-outline-primary:hover { transform: translateY(-1px); }
</style>