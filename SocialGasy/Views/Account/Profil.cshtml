@model SocialGasy.Models.User

@{
    ViewData["Title"] = "Mon Profil";
}

<div class="page-background-alt py-4 py-md-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <h4 class="mb-0 fw-bold">Mon Profil</h4>
                        <span class="badge bg-white text-primary mt-2 rounded-pill px-3">@Model.Role</span>
                    </div>
                    
                    <div class="card-body p-3 p-md-5 bg-white">
                        <form id="profileForm" asp-controller="Account" asp-action="UpdateProfile" method="post" enctype="multipart/form-data" autocomplete="off">
                            @Html.AntiForgeryToken()
                            
                            <!-- Sary Responsive -->
                            <div class="profile-img-wrapper text-center mb-4">
                                <div class="profile-img-container shadow">
                                    <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/images/default-avatar.png" : "/images/profiles/" + Model.ProfilePicture)" 
                                         alt="Photo de profil" 
                                         class="profile-img" />
                                </div>
                                
                                <div class="mt-3" id="editImage" style="display:none;">
                                    <label class="small text-muted mb-1">Changer la photo</label>
                                    <input type="file" name="file" class="form-control rounded-4" accept="image/*" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="fw-bold small text-dark">Nom complet</label>
                                <input type="text" name="FullName" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" value="@Model.FullName" disabled />
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold small text-dark">Email</label>
                                <input type="email" name="Email" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" value="@Model.Email" disabled />
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold small text-dark">Téléphone</label>
                                <input type="text" name="PhoneNumber" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" value="@Model.PhoneNumber" disabled />
                            </div>
                            <div class="mb-4">
                                <label class="fw-bold small text-dark">Adresse</label>
                                <input type="text" name="Address" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" value="@Model.Address" disabled />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" id="btnEdit" class="btn btn-primary btn-lg rounded-4 shadow-sm hover-lift fw-bold" onclick="enableEdit()">
                                    <i class="bi bi-pencil-square me-2"></i> Modifier le profil
                                </button>
                                <button type="submit" id="btnSave" class="btn btn-success btn-lg rounded-4 shadow-sm hover-lift fw-bold" style="display:none;">
                                    <i class="bi bi-save me-2"></i> Enregistrer les modifications
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }

    /* Fikirana ny sary mba ho responsive foana */
    .profile-img-container {
        width: 120px;
        height: 120px;
        margin: 0 auto;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #f8f9fa;
        background-color: #e9ecef;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@media (max-width: 576px) {
        .card-body { padding: 1.5rem !important; }
        .profile-img-container { width: 100px; height: 100px; }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>

<script>
    function enableEdit() {
        const inputs = document.querySelectorAll('#profileForm input');
        inputs.forEach(input => input.disabled = false);
        
        document.getElementById('btnEdit').style.display = 'none';
        document.getElementById('btnSave').style.display = 'block';
        document.getElementById('editImage').style.display = 'block';
    }
</script>