@model List<SocialGasy.Models.User>
@{
    ViewData["Title"] = "Gestion des Agents";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-white">
                <i class="bi bi-people-fill text-primary me-2"></i> Liste des Agents
            </h2>
            <a asp-action="CreateAgent" class="btn btn-primary btn-lg rounded-4 shadow-sm px-4 hover-lift">
                <i class="bi bi-plus-lg me-2"></i> Nouvel Agent
            </a>
        </div>

        <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small text-muted">Nom Complet</th>
                            <th class="py-3 text-uppercase small text-muted">CIN</th>
                            <th class="py-3 text-uppercase small text-muted">Téléphone</th>
                            <th class="py-3 text-uppercase small text-muted">Adresse</th>
                            <th class="text-center py-3 text-uppercase small text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.FullName</td>
                                <td>@item.Cin</td>
                                <td><span class="badge bg-light text-dark border">@item.PhoneNumber</span></td>
                                <td>@item.Address</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info px-3">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3" onclick="return confirm('Confirmer la suppression ?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                    <p class="mb-0">Aucun agent trouvé.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>