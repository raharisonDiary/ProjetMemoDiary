@model List<SocialGasy.Models.User>
@{
    ViewData["Title"] = "Gestion des Agents";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-people-fill text-primary me-2"></i> Liste des Agents
        </h2>
        <a asp-action="CreateAgent" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Nouvel Agent
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nom Complet</th>
                        <th>CIN</th>
                        <th>Téléphone</th>
                        <th>Adresse</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@item.FullName</td>
                            <td>@item.Cin</td>
                            <td>@item.PhoneNumber</td>
                            <td>@item.Address</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-start-pill px-3">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-end-pill px-3" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet agent ?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-3">Aucun agent trouvé pour le moment.</p>
            </div>
        }
    </div>
</div>