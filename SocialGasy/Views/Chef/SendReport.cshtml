@model SocialGasy.Models.Report

@{
    ViewData["Title"] = "Soumettre un Rapport";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
                    <div class="card-header bg-success text-white p-4 text-center border-0">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-send-fill me-2"></i> Soumettre un Rapport</h4>
                    </div>
                    
                    <div class="card-body p-4 p-md-5 bg-white">
                        <form asp-action="SendReport" method="post" autocomplete="off">
                            @Html.AntiForgeryToken()
                            
                            <div class="row g-3">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ChefName" class="form-label text-dark fw-bold small">Nom du Chef</label>
                                    <input asp-for="ChefName" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Nom complet" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ChefCin" class="form-label text-dark fw-bold small">CIN du Chef</label>
                                    <input asp-for="ChefCin" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Numéro CIN" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="TotalAgents" class="form-label text-dark fw-bold small">Nombre total d'agents</label>
                                <input asp-for="TotalAgents" type="number" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" placeholder="Ex: 10" required />
                            </div>

                            <div class="mb-4">
                                <label asp-for="Content" class="form-label text-dark fw-bold small">Contenu du rapport</label>
                                <textarea asp-for="Content" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" rows="6" placeholder="Détails du rapport ici..." required></textarea>
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                                <a asp-action="Dashboard" class="btn btn-outline-secondary btn-lg rounded-4 py-3 px-4 border-0 hover-lift">Annuler</a>
                                <button type="submit" class="btn btn-success btn-lg rounded-4 py-3 px-5 shadow-sm hover-lift fw-bold">
                                    <i class="bi bi-check-circle me-2"></i> Envoyer à l'Admin
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>