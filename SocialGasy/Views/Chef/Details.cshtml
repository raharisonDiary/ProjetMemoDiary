@model SocialGasy.Models.User

@{
    ViewData["Title"] = "Détails de l'Agent";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="bg-primary text-white p-4 rounded-top-4">
                    <h4 class="mb-0"><i class="bi bi-person-badge-fill me-2"></i> Profil de l'Agent</h4>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="row">
                        <div class="col-md-7">
                            <h5 class="fw-bold text-primary mb-3">Informations personnelles</h5>
                            <ul class="list-unstyled">
                                <li class="mb-3">
                                    <small class="text-muted text-uppercase d-block">Nom complet</small>
                                    <span class="fs-5 fw-semibold text-dark">@Model.FullName</span>
                                </li>
                                <li class="mb-3">
                                    <small class="text-muted text-uppercase d-block">CIN</small>
                                    <span class="fs-5 text-dark">@Model.Cin</span>
                                </li>
                                <li class="mb-3">
                                    <small class="text-muted text-uppercase d-block">Téléphone</small>
                                    <span class="fs-5 text-dark">@Model.PhoneNumber</span>
                                </li>
                                <li class="mb-3">
                                    <small class="text-muted text-uppercase d-block">Email</small>
                                    <span class="fs-5 text-dark">@Model.Email</span>
                                </li>
                                <li>
                                    <small class="text-muted text-uppercase d-block">Adresse</small>
                                    <span class="fs-5 text-dark">@Model.Address</span>
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-5 text-center mt-4 mt-md-0">
                            <div class="card border-0 bg-light p-3 rounded-4">
                                <h6 class="text-muted mb-3">QR Code d'identification</h6>
                                @if (Model.QrCodeImage != null && Model.QrCodeImage.Length > 0)
                                {
                                    var base64 = Convert.ToBase64String(Model.QrCodeImage);
                                    var imgSrc = String.Format("data:image/png;base64,{0}", base64);
                                    <img src="@imgSrc" alt="QR Code" class="img-fluid rounded-3 shadow-sm" />
                                }
                                else
                                {
                                    <div class="p-4 text-warning">
                                        <i class="bi bi-exclamation-triangle display-6"></i>
                                        <p class="mt-2">Aucun QR code généré.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white p-4 border-0 text-end">
                    <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i> Retour à la liste
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>