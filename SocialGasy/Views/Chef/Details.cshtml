@model SocialGasy.Models.User

@{
    ViewData["Title"] = "Détails de l'Agent";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-person-badge-fill me-2"></i> Profil de l'Agent</h4>
                    </div>
                    
                    <div class="card-body p-4 p-md-5 bg-white">
                        <div class="row">
                            <div class="col-md-7">
                                <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Informations personnelles</h5>
                                <ul class="list-unstyled">
                                    <li class="mb-4">
                                        <small class="text-muted text-uppercase fw-bold small">Nom complet</small>
                                        <div class="fs-5 fw-semibold text-dark">@Model.FullName</div>
                                    </li>
                                    <li class="mb-4">
                                        <small class="text-muted text-uppercase fw-bold small">CIN</small>
                                        <div class="fs-5 text-dark">@Model.Cin</div>
                                    </li>
                                    <li class="mb-4">
                                        <small class="text-muted text-uppercase fw-bold small">Téléphone</small>
                                        <div class="fs-5 text-dark">@Model.PhoneNumber</div>
                                    </li>
                                    <li class="mb-4">
                                        <small class="text-muted text-uppercase fw-bold small">Email</small>
                                        <div class="fs-5 text-dark">@Model.Email</div>
                                    </li>
                                    <li>
                                        <small class="text-muted text-uppercase fw-bold small">Adresse</small>
                                        <div class="fs-5 text-dark">@Model.Address</div>
                                    </li>
                                </ul>
                            </div>

                            <div class="col-md-5 text-center mt-4 mt-md-0">
                                <div class="card border-0 bg-light p-3 rounded-4 shadow-sm">
                                    <h6 class="text-muted mb-3 small fw-bold text-uppercase">QR Code d'identification</h6>
                                    @if (Model.QrCodeImage != null && Model.QrCodeImage.Length > 0)
                                    {
                                        var base64 = Convert.ToBase64String(Model.QrCodeImage);
                                        var imgSrc = String.Format("data:image/png;base64,{0}", base64);
                                        <img src="@imgSrc" alt="QR Code" class="img-fluid rounded-3" />
                                    }
                                    else
                                    {
                                        <div class="p-4 text-warning">
                                            <i class="bi bi-exclamation-triangle display-6"></i>
                                            <p class="mt-2 small">Aucun QR code généré.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white p-4 border-0 text-center">
                        <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-4 px-5 py-2 hover-lift">
                            <i class="bi bi-arrow-left me-2"></i> Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>