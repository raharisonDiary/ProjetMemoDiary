@model SocialGasy.Models.User

@{
    ViewData["Title"] = "Modifier l'Agent";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="bg-warning text-dark p-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Modifier les informations</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nom complet</label>
                                <input asp-for="FullName" class="form-control form-control-lg rounded-3" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">CIN</label>
                                <input asp-for="Cin" class="form-control form-control-lg rounded-3" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Téléphone</label>
                                <input asp-for="PhoneNumber" class="form-control form-control-lg rounded-3" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <input asp-for="Email" class="form-control form-control-lg rounded-3" type="email" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Adresse</label>
                            <input asp-for="Address" class="form-control form-control-lg rounded-3" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Dashboard" class="btn btn-outline-secondary btn-lg rounded-pill px-4 me-md-2">Annuler</a>
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-sm">
                                <i class="bi bi-save me-2"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>