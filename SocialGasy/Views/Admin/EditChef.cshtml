@model SocialGasy.Models.User
@{
    ViewData["Title"] = "Modifier le Chef";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-white p-4 rounded-top-4 border-0">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Modifier les informations du Chef</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-12 mb-2">
                                <label class="form-label fw-bold">Nom Complet</label>
                                <input asp-for="FullName" class="form-control form-control-lg rounded-3" required />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6 mb-2">
                                <label class="form-label fw-bold">Email</label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg rounded-3" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6 mb-2">
                                <label class="form-label fw-bold">Téléphone</label>
                                <input asp-for="PhoneNumber" class="form-control form-control-lg rounded-3" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label class="form-label fw-bold">Adresse</label>
                                <input asp-for="Address" class="form-control form-control-lg rounded-3" required />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="ListChefs" class="btn btn-outline-secondary btn-lg px-4 rounded-3">Annuler</a>
                            <button type="submit" class="btn btn-warning btn-lg px-4 rounded-3 text-white">
                                <i class="bi bi-check2-circle me-2"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}