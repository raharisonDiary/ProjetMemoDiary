@model SocialGasy.Models.User

@{
    ViewData["Title"] = "Modifier le Chef";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
                    <div class="card-header bg-warning text-dark p-4 text-center border-0">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Modifier les informations du Chef</h4>
                    </div>
                    
                    <div class="card-body p-4 p-md-5 bg-white">
                        <form asp-action="Edit" method="post" autocomplete="off">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Id" />

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label text-dark fw-bold small">Nom complet</label>
                                <input asp-for="FullName" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" required />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Email" class="form-label text-dark fw-bold small">Email</label>
                                    <input asp-for="Email" type="email" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" required />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PhoneNumber" class="form-label text-dark fw-bold small">Téléphone</label>
                                    <input asp-for="PhoneNumber" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" required />
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Address" class="form-label text-dark fw-bold small">Adresse</label>
                                <input asp-for="Address" class="form-control form-control-lg rounded-4 shadow-sm border-secondary border-opacity-25" required />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                                <a asp-action="ListChefs" class="btn btn-outline-secondary btn-lg rounded-4 py-3 px-4 border-0 hover-lift">Annuler</a>
                                <button type="submit" class="btn btn-primary btn-lg rounded-4 py-3 px-5 shadow-sm hover-lift fw-bold">
                                    <i class="bi bi-save me-2"></i> Enregistrer
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}