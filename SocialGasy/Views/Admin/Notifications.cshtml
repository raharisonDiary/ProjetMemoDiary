@model IEnumerable<SocialGasy.Models.Report>

@{
    ViewData["Title"] = "Rapports Reçus";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        
        <div class="d-flex align-items-center mb-4">
            <h2 class="fw-bold text-white mb-0">
                <i class="bi bi-envelope-paper-fill text-warning me-3"></i> Rapports Reçus
            </h2>
        </div>

        <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small text-muted">Statut</th>
                            <th class="py-3 text-uppercase small text-muted">Chef Régional</th>
                            <th class="py-3 text-uppercase small text-muted">Date</th>
                            <th class="text-center py-3 text-uppercase small text-muted">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr class="@(r.IsRead ? "" : "table-light")">
                                <td class="ps-4">
                                    @if (r.IsRead)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                            <i class="bi bi-check-all"></i> Lu
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2">
                                            <i class="bi bi-exclamation-circle"></i> Non lu
                                        </span>
                                    }
                                </td>
                                <td class="fw-bold text-dark">@r.ChefName</td>
                                <td class="text-muted small">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <a asp-action="JereoRapport" asp-route-id="@r.Id" 
                                       class="btn btn-sm btn-primary rounded-4 px-4 py-2 hover-lift">
                                        Consulter
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-envelope-slash display-4 d-block mb-3"></i>
                    <p class="mb-0">Aucun rapport reçu pour le moment.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>