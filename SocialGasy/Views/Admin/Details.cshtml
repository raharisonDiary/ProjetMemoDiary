@model SocialGasy.Models.User
@{
    ViewData["Title"] = "Détails du Chef";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="bg-primary text-white p-4 text-center">
                    <h3 class="mb-0 fw-bold">@Model.FullName</h3>
                    <span class="badge bg-light text-primary mt-2 rounded-pill px-3">@Model.Role</span>
                </div>

                <!-- Body -->
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Informations Personnelles</h5>
                    
                    <div class="mb-3">
                        <label class="text-muted small text-uppercase fw-bold">Nom d'utilisateur</label>
                        <p class="fs-5 fw-medium text-dark">@Model.Username</p>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small text-uppercase fw-bold">Email</label>
                            <p class="fw-medium text-dark">@Model.Email</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small text-uppercase fw-bold">Téléphone</label>
                            <p class="fw-medium text-dark">@Model.PhoneNumber</p>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold">Numéro CIN</label>
                        <p class="fw-medium text-dark">@Model.Cin</p>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold">Adresse</label>
                        <p class="fw-medium text-dark">@Model.Address</p>
                    </div>

                    <!-- QR Section -->
                    <div class="text-center mt-5 p-3 bg-light rounded-4">
                        <h5 class="fw-bold mb-3">QR Code d'Authentification</h5>
                        @if (Model.QrCodeImage != null)
                        {
                            <img src="data:image/png;base64,@Convert.ToBase64String(Model.QrCodeImage)" 
                                 alt="QR Code" 
                                 class="img-fluid border p-2 bg-white rounded-3 shadow-sm" 
                                 style="max-width: 200px;" />
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">Aucun QR Code disponible.</div>
                        }
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <div class="d-grid">
                        <a asp-action="ListChefs" class="btn btn-outline-secondary btn-lg rounded-3">
                            <i class="bi bi-arrow-left me-2"></i> Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>