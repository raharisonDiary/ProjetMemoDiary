@model IEnumerable<SocialGasy.Models.User>
@{ ViewData["Title"] = "Liste des Chefs"; }

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h2 class="fw-bold text-dark"><i class="bi bi-person-badge-fill text-primary"></i> Liste des Chefs Régionaux</h2>
        <a asp-action="CreateChef" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Ajouter un Chef
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nom Complet</th>
                        <th>Nom d'utilisateur</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var chef in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@chef.FullName</td>
                            <td>@chef.Username</td>
                            <td class="text-center">
                                <div class="btn-group gap-1" role="group">
                                    <a asp-action="Details" asp-route-id="@chef.Id" class="btn btn-outline-info btn-sm rounded">Détails</a>
                                    <a asp-action="Edit" asp-route-id="@chef.Id" class="btn btn-outline-warning btn-sm rounded">Modifier</a>
                                    <a asp-action="Delete" asp-route-id="@chef.Id" class="btn btn-outline-danger btn-sm rounded">Supprimer</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .card { background: #ffffff; }
    .table thead th { border-bottom: 2px solid #f8f9fa; padding: 1rem; }
    .table tbody td { padding: 1rem; }
    .btn-group .btn { transition: all 0.2s; }
    .btn-group .btn:hover { transform: translateY(-2px); }
</style>