@using SocialGasy.Models
@model IEnumerable<SocialGasy.Models.Report>

@{
    ViewData["Title"] = "Tableau de Bord Administrateur";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-speedometer2 text-primary"></i> Tableau de Bord</h2>
    </div>

    <!-- Stats Widget -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-3">
                <div class="card-body">
                    <h6 class="text-uppercase opacity-75">Rapports Totaux</h6>
                    <h2 class="display-5 fw-bold">@(Model?.Count() ?? 0)</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white p-3 border-0">
            <h5 class="mb-0 fw-bold text-secondary">Liste des Rapports</h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Statut</th>
                                <th>Chef Régional</th>
                                <th>Contenu</th>
                                <th>Date</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tatitra in Model)
                            {
                                <tr class="@(tatitra.IsRead ? "" : "table-warning-subtle")">
                                    <td class="ps-4">
                                        @if (tatitra.IsRead)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3">Lu</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning rounded-pill px-3">Non lu</span>
                                        }
                                    </td>
                                    <td class="fw-semibold">@tatitra.ChefName</td>
                                    <td class="text-truncate" style="max-width: 250px;">@tatitra.Content</td>
                                    <td>@tatitra.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <a href="@Url.Action("JereoRapport", "Admin", new { id = tatitra.Id })" 
                                           class="btn btn-sm @(tatitra.IsRead ? "btn-outline-secondary" : "btn-primary") rounded-pill px-3">
                                            @(tatitra.IsRead ? "Voir à nouveau" : "Consulter")
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center">
                    <p class="text-muted">Aucun rapport trouvé pour le moment.</p>
                </div>
            }
        </div>
    </div>
</div>