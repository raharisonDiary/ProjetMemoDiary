@using SocialGasy.Models
@model IEnumerable<SocialGasy.Models.Report>

@{
    ViewData["Title"] = "Tableau de Bord Administrateur";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-white">
                <i class="bi bi-speedometer2 text-warning me-2"></i> Tableau de Bord
            </h2>
        </div>

        <!-- Stats Card -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-lg border-0 rounded-5 bg-primary text-white p-3">
                    <div class="card-body">
                        <h6 class="text-uppercase opacity-75 small">Rapports Totaux</h6>
                        <h2 class="display-5 fw-bold mb-0">@(Model?.Count() ?? 0)</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reports Table -->
        <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
            <div class="card-header bg-white p-4 border-0">
                <h5 class="mb-0 fw-bold text-dark">Liste des Rapports</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small text-muted">Statut</th>
                            <th class="py-3 text-uppercase small text-muted">Chef Régional</th>
                            <th class="py-3 text-uppercase small text-muted">Contenu</th>
                            <th class="py-3 text-uppercase small text-muted">Date</th>
                            <th class="text-center py-3 text-uppercase small text-muted">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tatitra in Model)
                        {
                            <tr class="@(tatitra.IsRead ? "" : "table-light")">
                                <td class="ps-4">
                                    @if (tatitra.IsRead)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Lu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Non lu</span>
                                    }
                                </td>
                                <td class="fw-bold text-dark">@tatitra.ChefName</td>
                                <td class="text-muted text-truncate" style="max-width: 250px;">@tatitra.Content</td>
                                <td class="text-muted small">@tatitra.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <a href="@Url.Action("JereoRapport", "Admin", new { id = tatitra.Id })" 
                                       class="btn btn-sm @(tatitra.IsRead ? "btn-outline-secondary" : "btn-primary") rounded-4 px-3 hover-lift">
                                        @(tatitra.IsRead ? "Voir" : "Consulter")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-file-earmark-text display-4 d-block mb-3"></i>
                    <p class="mb-0">Aucun rapport trouvé pour le moment.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>