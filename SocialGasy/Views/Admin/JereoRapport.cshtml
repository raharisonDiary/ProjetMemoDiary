@model SocialGasy.Models.Report
@{
    ViewData["Title"] = "Détails du Rapport";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="bg-primary text-white p-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text-fill me-2"></i> Détails du Rapport</h4>
                </div>

                <!-- Body -->
                <div class="card-body p-4 p-md-5">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted small text-uppercase">Chef Régional</dt>
                        <dd class="col-sm-8 fw-bold text-dark fs-6">@Model.ChefName</dd>

                        <dt class="col-sm-4 text-muted small text-uppercase mt-3">Numéro CIN</dt>
                        <dd class="col-sm-8 text-dark fs-6 mt-3">@Model.ChefCin</dd>

                        <dt class="col-sm-4 text-muted small text-uppercase mt-3">Nombre d'agents</dt>
                        <dd class="col-sm-8 text-dark fs-6 mt-3">@Model.TotalAgents</dd>

                        <dt class="col-sm-4 text-muted small text-uppercase mt-3">Date</dt>
                        <dd class="col-sm-8 text-dark fs-6 mt-3">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4 text-muted small text-uppercase mt-3">Statut</dt>
                        <dd class="col-sm-8 mt-3">
                            <span class="badge bg-info rounded-pill px-3">@Model.Status</span>
                        </dd>
                    </dl>

                    <div class="mt-4">
                        <label class="text-muted small text-uppercase fw-bold">Contenu du message</label>
                        <div class="p-4 bg-light border-0 rounded-4 mt-2 text-secondary shadow-inner">
                            @Model.Content
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <a asp-action="Notifications" class="btn btn-outline-secondary btn-lg rounded-3 px-4">
                        <i class="bi bi-arrow-left me-2"></i> Retour à la liste
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>