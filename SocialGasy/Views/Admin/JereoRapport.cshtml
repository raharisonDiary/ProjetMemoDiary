@model SocialGasy.Models.Report

@{
    ViewData["Title"] = "Détails du Rapport";
}

<div class="page-background-alt py-5">
    <div class="container animate__animated animate__fadeIn">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-5 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text-fill me-2"></i> Détails du Rapport</h4>
                    </div>
                    
                    <div class="card-body p-4 p-md-5 bg-white">
                        <div class="row mb-4">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">Chef Régional</div>
                            <div class="col-sm-8 fw-bold text-dark">@Model.ChefName</div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">Numéro CIN</div>
                            <div class="col-sm-8 text-dark">@Model.ChefCin</div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">Nombre d'agents</div>
                            <div class="col-sm-8 text-dark">@Model.TotalAgents</div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">Date</div>
                            <div class="col-sm-8 text-dark">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">Statut</div>
                            <div class="col-sm-8">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">@Model.Status</span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label class="text-muted small text-uppercase fw-bold mb-2">Contenu du message</label>
                            <div class="p-4 rounded-4 border-start border-4 border-primary bg-light text-secondary">
                                @Model.Content
                            </div>
                        </div>

                        <div class="mt-5">
                            <a asp-action="Notifications" class="btn btn-outline-secondary btn-lg rounded-4 py-3 px-4 hover-lift">
                                <i class="bi bi-arrow-left me-2"></i> Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-background-alt {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
    }
    .hover-lift { transition: transform 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate__fadeIn { animation: fadeIn 0.8s ease-out forwards; }
</style>