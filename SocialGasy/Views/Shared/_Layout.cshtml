@using Microsoft.Extensions.Localization
@using SocialGasy
@inject IStringLocalizer<SharedResource> Localizer

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SocialGasy</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="sidebar-overlay"></div>
    <div class="d-flex" id="wrapper">
        
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div id="sidebar-wrapper">
                <div class="sidebar-heading px-3 py-4 fs-5 fw-bold text-white">
                    <i class="bi bi-shield-check text-primary"></i> SOCIAL GASY
                </div>
                <div class="list-group list-group-flush px-2">
                    <a class="nav-link-sidebar @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-2"></i> Tableau de bord
                    </a>
                    <a class="nav-link-sidebar @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Household" ? "active" : "")" 
                       asp-controller="Household" asp-action="Index">
                        <i class="bi bi-houses me-2"></i> Ménages
                    </a>
                    <a class="nav-link-sidebar @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Citizen" ? "active" : "")" 
                       asp-controller="Citizen" asp-action="Index">
                        <i class="bi bi-people me-2"></i> Habitants
                    </a>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link-sidebar @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Stats" ? "active" : "")" 
                           asp-controller="Stats" asp-action="Index">
                            <i class="bi bi-graph-up-arrow me-2"></i> Statistiques
                        </a>
                    }
                    
                    @if (User.IsInRole("ChefRegional"))
                    {
                        <div class="small text-muted mt-4 mb-2 px-3 text-uppercase fw-bold">Espace Chef</div>
                        <a class="nav-link-sidebar" asp-controller="Chef" asp-action="Dashboard">
                            <i class="bi bi-person-badge me-2"></i> Dashboard Chef
                        </a>
                        <a class="nav-link-sidebar" asp-controller="Chef" asp-action="SendReport">
                            <i class="bi bi-file-earmark-text me-2"></i> Envoyer le rapport
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="small text-muted mt-4 mb-2 px-3 text-uppercase fw-bold">Administrateur</div>
                        <a class="nav-link-sidebar" asp-controller="Admin" asp-action="Dashboard">
                            <i class="bi bi-person-gear me-2"></i> Rapports
                        </a>
                        <a class="nav-link-sidebar" asp-controller="Admin" asp-action="ListChefs">
                            <i class="bi bi-people-fill me-2"></i> Liste des chefs
                        </a>
                    }

                    <div class="small text-muted mt-4 mb-2 px-3 text-uppercase fw-bold">Informations</div>
                    <a class="nav-link-sidebar" asp-controller="Home" asp-action="About">
                        <i class="bi bi-info-circle me-2"></i> À propos
                    </a>
                </div>
            </div>
        }

        <div id="page-content-wrapper" class="w-100">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4 sticky-top">
                    <button class="btn btn-light d-md-none me-3" id="menu-toggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="ms-auto">
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-dark d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="avatar-circle me-2">
                                    @(User.Identity.Name?.Substring(0, 1) ?? "U")
                                </div>
                                <span class="d-none d-sm-inline">@(User.Identity.Name ?? "Utilisateur")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profil"><i class="bi bi-person me-2"></i> Profil</a></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
            }

            <div class="container-fluid p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    </div>
                }
                @RenderBody()
            </div>

            <footer class="text-center py-4 text-muted small mt-auto border-top">
                &copy; 2026 - <strong>SocialGasy</strong>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#menu-toggle").click(function(e) {
                e.preventDefault();
                $("#wrapper").toggleClass("toggled");
                $("#sidebar-overlay").fadeToggle();
            });
            $("#sidebar-overlay").click(function() {
                $("#wrapper").toggleClass("toggled");
                $(this).fadeToggle();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>